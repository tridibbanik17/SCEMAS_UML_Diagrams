@startuml access_management_controller
hide empty description

skinparam state {
  BackgroundColor<<signup>> #EDE8F5
  BorderColor<<signup>> #a692c3
  FontColor<<signup>> #4A3767

  BackgroundColor<<init>> #F2F4F4
  BorderColor<<init>> #7F8C8D
  FontColor<<init>> #2C3E50

  BackgroundColor<<auth>> #FCEAE8
  BorderColor<<auth>> #ea9a97
  FontColor<<auth>> #6B3A38

  BackgroundColor<<entry>> #D6EAF8
  BorderColor<<entry>> #2980B9
  FontColor<<entry>> #1A5276

  BackgroundColor<<log>> #D5F5E3
  BorderColor<<log>> #27AE60
  FontColor<<log>> #1E8449

  BackgroundColor<<error>> #FDEBD0
  BorderColor<<error>> #E67E22
  FontColor<<error>> #7E5109
  
  BackgroundColor<<modify>> #FFCCCB
  BorderColor<<modify>> #FF3431
  FontColor<<modify>> #FF1111

  StartColor black
  EndColor black
}

' ──────────────────────────────────
' TOP-LEVEL LIFECYCLE
' ──────────────────────────────────

state "Initializing" as INIT <<init>> {
  state "ConnectDataSources" as CDS <<init>>
  state "LoadAccountDB" as ADB <<init>>
  CDS --> ADB : sources available
}

state "EntryDashboard" as ED <<entry>>{
  
  state "DisplayDashboard" as DD <<entry>>
  DD --> SU : user input
  DD --> LOG : user input
  
  state "SignUp" as SU <<signup>> {
  state "CollectUserInfo" as CUI <<signup>>
  state "DeviceRegistry" as DR <<signup>>
  state "StoreAccountDB" as SADB <<signup>>
  CUI --> DR : info collected
  DR --> SADB : device registered
  SADB --> LOG : user registered
  SU --> DD : returns
}

  state "Login" as LOG <<log>> {
  state "Authenticating" as AUTH <<log>> {
  state "ValidateToken" as VT <<log>>
  state "SecurityPermissions" as SP <<log>>
  state "AuthorizeRole" as AR <<log>>
  VT --> SP : token valid
  SP --> AR : compare with perms
  AR --> ST : user identified
  LOG --> DD : returns
  
}
  state "SessionToken" as ST <<log>>
}

}

state "ModifyAccount" as MA <<modify>> {
    state "UpdateUserInfo" as UUI <<modify>>
    state "UpdateAccountDB" as UADB <<modify>>
    state "DisplayUser" as DU <<modify>>
    UUI --> UADB : info received
    UADB --> DU : displays new info
    DU --> UUI : user input
}


state "Error" as ERR <<error>> {
  state "LogFailure" as LF <<error>>
  state "NotifyAdmin" as NA <<error>>
  state "AttemptRecovery" as REC <<error>>
  LF --> NA : failure logged
  NA --> REC : admin notified
}



' ──────────────────────────────────
' TRANSITIONS
' ──────────────────────────────────

[*] --> INIT : controller startup

INIT --> ED : initialization complete
INIT --> ERR : data source unavailable

ED --> ERR : authentication failed
ED --> MA : successful login

MA --> ERR : faulty input

ERR --> INIT : recovery: reinitialize
ERR --> [*] : unrecoverable failure

@enduml
